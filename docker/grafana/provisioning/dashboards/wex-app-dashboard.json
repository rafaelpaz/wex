  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 9,
      "title": "Total Requests — POST /purchase-transactions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(http_server_requests_seconds_count{method=\"POST\", uri=\"/api/v1/purchase-transactions\"})", "legendFormat": "POST /api/v1/purchase-transactions", "refId": "A" }]
    },
    {
      "id": 11,
      "title": "Total Requests — GET /purchase-transactions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(http_server_requests_seconds_count{method=\"GET\", uri=\"/api/v1/purchase-transactions\"})", "legendFormat": "GET /api/v1/purchase-transactions", "refId": "A" }]
    },
    {
      "id": 10,
      "title": "Total Requests — GET /purchase-transactions/{id}",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "targets": [{ "expr": "sum(http_server_requests_seconds_count{method=\"GET\", uri=\"/api/v1/purchase-transactions/{id}\"})", "legendFormat": "GET /api/v1/purchase-transactions/{id}", "refId": "A" }]
    },
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/.*\"}[1m])) by (method, uri)", "legendFormat": "{{method}} {{uri}}", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "http_server_requests_seconds_max{uri=~\"/api/v1/.*\"}", "legendFormat": "{{method}} {{uri}} ({{instance}})", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "HTTP Responses by Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/v1/.*\"}[1m])) by (status)", "legendFormat": "HTTP {{status}}", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "jvm_memory_used_bytes{area=\"heap\"}", "legendFormat": "{{instance}} - {{id}}", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [
        { "expr": "hikaricp_connections_active{pool=\"HikariPool-1\"}", "legendFormat": "Active ({{instance}})", "refId": "A" },
        { "expr": "hikaricp_connections_idle{pool=\"HikariPool-1\"}", "legendFormat": "Idle ({{instance}})", "refId": "B" },
        { "expr": "hikaricp_connections_pending{pool=\"HikariPool-1\"}", "legendFormat": "Pending ({{instance}})", "refId": "C" }
      ]
    },
    {
      "id": 6,
      "title": "JVM GC Pause Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "rate(jvm_gc_pause_seconds_sum[1m])", "legendFormat": "GC pause ({{instance}})", "refId": "A" }]
    },
    {
      "id": 7,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "Live ({{instance}})", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "Daemon ({{instance}})", "refId": "B" }
      ]
    },
    {
      "id": 8,
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": true } }, "overrides": [] },
      "targets": [{ "expr": "process_cpu_usage", "legendFormat": "CPU ({{instance}})", "refId": "A" }]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["wex", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
