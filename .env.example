# =============================================================================
# Docker Compose Environment
# Copy this file to .env and adjust values as needed:  cp .env.example .env
# =============================================================================

# Spring Profile
SPRING_PROFILES_ACTIVE=docker

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/wex_transactions
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=wex
SPRING_DATASOURCE_PASSWORD=wex_password
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Redis Cache
SPRING_CACHE_TYPE=redis
SPRING_CACHE_REDIS_TIME_TO_LIVE=3600s
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_TIMEOUT=5000ms

# Actuator
MANAGEMENT_HEALTH_REDIS_ENABLED=true
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus

# Server
SERVER_FORWARD_HEADERS_STRATEGY=framework
